global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'node_exporter'
    static_configs:
      - targets:
        - '10.0.1.38:9100'   # monitoring-server
        - '10.0.2.13:9100'   # web-server-a
        - '10.0.4.15:9100'   # web-server-b
        - '10.0.1.15:9100'   # logging-server
        - '10.0.1.13:9100'   # bastion-host

  - job_name: 'nginx'
    static_configs:
      - targets:
        - '10.0.2.13:9113'   # web-server-a nginx exporter
        - '10.0.4.15:9113'   # web-server-b nginx exporter